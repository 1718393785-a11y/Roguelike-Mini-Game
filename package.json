{
  "name": "zero-downtime-refactor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "baseline": "node tools/run-baseline.mjs --browser chrome",
    "baseline:e2e": "node tests/e2e/run-baseline.mjs --browser chrome --record tests/recordings/smoke.json",
    "baseline:flags": "node tools/run-baseline.mjs --browser chrome --compare-enabled-flags --json-config --system-split --generic-weapon --pixi-renderer --hot-reload",
    "baseline:generic-weapons": "node tools/run-baseline.mjs --browser chrome --compare-generic-weapon-matrix --seconds 30",
    "baseline:generic-weapon-levels": "node tools/run-baseline.mjs --browser chrome --compare-generic-weapon-matrix --seconds 10 --levels 1,2,3,4,5,6",
    "validate:config": "tsx src/config/validateSpec.ts",
    "validate:hot-reload": "tsx src/config/validateHotReload.ts",
    "validate:hot-reload:browser": "node tools/run-hot-reload-check.mjs",
    "validate:pixi-renderer": "node tools/run-pixi-renderer-check.mjs",
    "validate:entity-stress": "node tools/run-entity-stress.mjs",
    "validate:damage": "node tools/run-damage-regression.mjs --browser chrome",
    "validate:assets": "node tools/validate-assets.mjs",
    "normalize:asset-prompts": "node tools/normalize-asset-queue.mjs",
    "generate:art-a1-a2": "node tools/generate-a1-a2-assets.mjs",
    "generate:art-a3": "node tools/generate-a3-enemy-assets.mjs",
    "generate:art-a4": "node tools/generate-a4-player-assets.mjs",
    "generate:art-a5": "node tools/generate-a5-boss-assets.mjs",
    "generate:art-a6": "node tools/generate-a6-tile-assets.mjs",
    "generate:art-a7": "node tools/generate-a7-weapon-progression-effects.mjs",
    "generate:art-a8": "node tools/generate-a8-ui-skin-assets.mjs",
    "generate:art-a9": "node tools/generate-a9-enemy-animation-assets.mjs",
    "generate:art-a10": "node tools/generate-a10-boss-animation-assets.mjs",
    "validate:weapons": "tsx src/effects/validateGenericWeapons.ts",
    "validate:effects": "tsx src/effects/validateEffectGeometry.ts",
    "check:architecture": "node tools/check-architecture.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "vite --host 127.0.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "playwright-core": "^1.56.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "pixi.js": "^8.18.1",
    "zod": "^4.3.6"
  }
}
