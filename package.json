{
  "name": "zero-downtime-refactor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "baseline": "node tools/run-baseline.mjs --browser chrome",
    "baseline:e2e": "node tests/e2e/run-baseline.mjs --browser chrome --record tests/recordings/smoke.json",
    "baseline:flags": "node tools/run-baseline.mjs --browser chrome --compare-enabled-flags --json-config --system-split --generic-weapon --pixi-renderer --hot-reload",
    "baseline:generic-weapons": "node tools/run-baseline.mjs --browser chrome --compare-generic-weapon-matrix --seconds 30",
    "baseline:generic-weapon-levels": "node tools/run-baseline.mjs --browser chrome --compare-generic-weapon-matrix --seconds 10 --levels 1,2,3,4,5,6",
    "validate:config": "tsx src/config/validateSpec.ts",
    "validate:hot-reload": "tsx src/config/validateHotReload.ts",
    "validate:weapons": "tsx src/effects/validateGenericWeapons.ts",
    "validate:effects": "tsx src/effects/validateEffectGeometry.ts",
    "check:architecture": "node tools/check-architecture.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "vite --host 127.0.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "playwright-core": "^1.56.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
